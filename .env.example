TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Optional: comma-separated Telegram chat IDs that receive proxy alerts.
ADMIN_CHAT_IDS=

# Optional: base64-encoded Netscape cookies.txt files.
# Example: base64 -w0 cookies.txt
INSTAGRAM_COOKIES_BASE64=
YOUTUBE_COOKIES_BASE64=
TIKTOK_COOKIES_BASE64=
TWITTER_COOKIES_BASE64=

# Optional: comma-separated proxies. Accepted formats:
# - http://user:pass@host:port
# - socks5://user:pass@host:port
# - host:port:user:pass
PROXY_LIST=

# Optional bounded parallelism. Increase carefully to avoid Telegram/API limits.
MAX_PARALLEL_DOWNLOADS=3
MAX_PARALLEL_UPLOADS=2
MAX_PARALLEL_FFMPEG=1
MAX_LINKS_PER_MESSAGE=20
